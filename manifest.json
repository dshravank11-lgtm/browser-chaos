{
    "manifest_version": 3,
    "name": "Browser Chaos 67",
    "version": "3",
    "icons": {"128": "skull.png"},
    "description": "Chaos in your browser",
    "permissions": ["storage", "alarms", "tabs", "scripting"],
    "host_permissions": ["<all_urls>"],
    "action": {"default_popup": "popup.html"},
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"]
        }
    ],
    "chrome_url_overrides": {
        "newtab": "newtab.html"
    },
    "web_accessible_resources": [{
        "resources": ["skull.png", "phonk.mp3", "phonk1.mp3", "phonk2.mp3", "phonk3.mp3", "hand.png", "blockmine1.png", "blockmine2.png", "minecraft.png"],
        "matches": ["<all_urls>"]
    }],
    "background": {
        "service_worker": "background.js"
    }
}
